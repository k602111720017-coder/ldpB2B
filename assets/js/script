    if(document.readyState !== 'loading') fn();
    else document.addEventListener('DOMContentLoaded', fn);
  }
  ready(function(){
    if(!document.getElementById('imgLightbox')){
      var lb = document.createElement('div');
      lb.id = 'imgLightbox';
      lb.className = 'img-lightbox';
      lb.innerHTML = '<div class="img-lightbox-card" role="dialog" aria-modal="true" aria-label="Xem ảnh phóng to"><div class="img-lightbox-head"><div><div class="img-lightbox-title">Xem ảnh chi tiết</div><div class="img-lightbox-sub">Ảnh được mở ở kích thước lớn hơn để xem rõ nội dung</div></div><button type="button" class="img-lightbox-close" aria-label="Đóng">×</button></div><div class="img-lightbox-img-wrap"><img alt="Ảnh phóng to"></div><div class="img-lightbox-caption"></div></div>';
      document.body.appendChild(lb);
    }
    var lb = document.getElementById('imgLightbox');
    var img = lb.querySelector('img');
    var cap = lb.querySelector('.img-lightbox-caption');
    var close = lb.querySelector('.img-lightbox-close');
    var wrap = lb.querySelector('.img-lightbox-img-wrap');
    function openLightbox(source){
      var full = source.getAttribute('data-full') || source.currentSrc || source.src;
      img.src = full;
      img.alt = source.alt || 'Ảnh phóng to';
      cap.textContent = (source.alt || 'Ảnh chi tiết') + ' · Bấm ra ngoài hoặc nhấn ESC để đóng';
      wrap.scrollTop = 0;
      wrap.scrollLeft = 0;
      lb.classList.add('open');
      document.body.classList.add('img-lightbox-open');
    }
    function closeLightbox(){
      lb.classList.remove('open');
      document.body.classList.remove('img-lightbox-open');
      setTimeout(function(){ if(!lb.classList.contains('open')) img.removeAttribute('src'); }, 120);
    }
    document.querySelectorAll('.v3-flow-thumb img, .v3-sol-thumb img, .v3-ai-media img, #flow img, #solution img, #ai img').forEach(function(el){
      if(el.dataset.lbBound === '1') return;
      el.dataset.lbBound = '1';
      el.setAttribute('title', 'Click để phóng to ảnh');
      el.addEventListener('click', function(e){
        e.preventDefault();
        e.stopPropagation();
        openLightbox(el);
      });
    });
    close.addEventListener('click', closeLightbox);
    lb.addEventListener('click', function(e){ if(e.target === lb) closeLightbox(); });
    document.addEventListener('keydown', function(e){ if(e.key === 'Escape' && lb.classList.contains('open')) closeLightbox(); });
  });
})();
