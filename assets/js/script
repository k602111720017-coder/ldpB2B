// FORM VALIDATION
(function(){
  const df=document.getElementById('df');
  if(!df)return;
  df.addEventListener('submit',function(e){
    e.preventDefault();
    const rules=[
      ['fg-company','f-company','text'],
      ['fg-name','f-name','text'],
      ['fg-title','f-title','sel'],
      ['fg-email','f-email','email'],
      ['fg-phone','f-phone','phone'],
      ['fg-region','f-region','sel'],
      ['fg-size','f-size','sel'],
      ['fg-industry','f-industry','sel'],
      ['fg-problem','f-problem','sel'],
    ];
    let ok=true;
    rules.forEach(([g,f,t])=>{
      const fg=document.getElementById(g),el=document.getElementById(f);
      if(!fg||!el)return;
      let v=true;
      if(t==='text')v=el.value.trim().length>1;
      else if(t==='sel')v=el.value!=='';
      else if(t==='phone')v=/^[0-9]{9,11}$/.test(el.value.replace(/\s/g,''));
      else if(t==='email')v=/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(el.value.trim());
      else if(t==='check')v=fg.querySelectorAll('input[type=checkbox]:checked').length>0;
      fg.classList.toggle('err',!v);
      if(!v)ok=false;
    });
    if(ok){
      df.style.display='none';
      const s=document.getElementById('form-ok');
      if(s){s.style.display='block';s.scrollIntoView({behavior:'smooth',block:'center'});}
    }
  });
})();

