// ── RIPPLE EFFECT (brand guidelines §5) ──
document.addEventListener('click',function(e){
  var btn=e.target.closest('.btn-p,.form-sub-btn');
  if(!btn)return;
  var r=btn.getBoundingClientRect();
  var x=e.clientX-r.left, y=e.clientY-r.top;
  var sz=Math.max(r.width,r.height);
  ['ripple-fill','ripple-ring'].forEach(function(cls){
    var el=document.createElement('span');
    el.className=cls;
    el.style.cssText='width:'+sz+'px;height:'+sz+'px;left:'+(x-sz/2)+'px;top:'+(y-sz/2)+'px';
    btn.appendChild(el);
    el.addEventListener('animationend',function(){el.remove();});
  });
});

// ── COUNT-UP ──
function countUp(el){
  var target=parseFloat(el.dataset.target);
  var suffix=el.dataset.suffix||'';
  var dec=el.dataset.decimals?parseInt(el.dataset.decimals):0;
  var sep=el.dataset.sep||'';
  var dur=2000,start=performance.now();
  function fmt(n){
    var s=n.toFixed(dec);
    if(sep){var parts=s.split('.');parts[0]=parts[0].replace(/\B(?=(\d{3})+(?!\d))/g,sep);s=parts.join('.');}
    return s+suffix;
  }
  function upd(now){
    var p=Math.min((now-start)/dur,1);
    var ease=1-(1-p)*(1-p);
    el.textContent=fmt(target*ease);
    if(p<1)requestAnimationFrame(upd);
    else el.textContent=fmt(target);
  }
  requestAnimationFrame(upd);
}
(function(){
  var obs=new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if(e.isIntersecting){countUp(e.target);obs.unobserve(e.target);}
    });
  },{threshold:0.3});
  document.querySelectorAll('.count-up').forEach(function(el){obs.observe(el);});
})();

// ── SCROLLSPY - active nav link ──
(function(){
  var secs=['pain','flow','solution','ai','roles','faq'];
  var links={};
  secs.forEach(function(id){
    var a=document.querySelector('.nav-links a[href="#'+id+'"]');
    if(a)links[id]=a;
  });
  var obs2=new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      var id=e.target.id;
      if(links[id])links[id].classList.toggle('nav-on',e.isIntersecting);
    });
  },{threshold:0.25,rootMargin:'-68px 0px 0px 0px'});
  secs.forEach(function(id){
    var sec=document.getElementById(id);
    if(sec)obs2.observe(sec);
  });
})();

