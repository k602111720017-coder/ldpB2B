// ── HERO FLOW ANIMATION ──
(function(){
  var steps=[0,1,2,3,4];
  var cur=2;
  function activate(i){
    steps.forEach(function(s){
      var el=document.getElementById('hfs'+s);
      if(!el)return;
      el.classList.remove('hf-active','hf-step-dim');
      if(s<i){}
      else if(s===i){el.classList.add('hf-active');}
      else{el.classList.add('hf-step-dim');}
      // update badge
      var badge=el.querySelector('.hf-step-badge');
      if(badge){
        badge.className='hf-step-badge';
        if(s<i){badge.className+=' badge-done';badge.textContent='Xong';}
        else if(s===i){badge.className+=' badge-active';badge.textContent='Đang chạy';}
        else{badge.className+=' badge-wait';badge.textContent='Chờ';}
      }
    });
  }
  function next(){cur=(cur+1)%5;activate(cur);}
  activate(cur);
  setInterval(next,2800);
})();

